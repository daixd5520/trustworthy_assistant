# Anthropic API Configuration
ANTHROPIC_API_KEY=your_api_key_here

# Model ID (default: claude-sonnet-4-20250514)
MODEL_ID=claude-sonnet-4-20250514

# Optional: Custom base URL for Anthropic API
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: OpenAI embeddings
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: Dedicated vision tool backend for `read_image`
# VISION_API_KEY=sk-xxxxx
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_MODEL_ID=gpt-4.1-mini
# MiniMax example:
# VISION_API_KEY=your_minimax_key_with_vl01_access
# VISION_BASE_URL=https://api.minimaxi.com/v1
# VISION_MODEL_ID=MiniMax-VL-01
# EMBEDDING_MODEL=text-embedding-3-small
# CHROMA_PERSIST_DIR=./chroma

# Optional: WeCom bot
# WECOM_CORP_ID=wwxxxxxxxxx
# WECOM_AGENT_ID=1000001
# WECOM_SECRET=xxxxxxxxxxxxx

# Optional: Personal WeChat via iLink / ClawBot
# WECHAT_ILINK_BASE_URL=https://ilinkai.weixin.qq.com
# WECHAT_QR_BOT_TYPE=3
# WECHAT_ACCOUNT_ID=
